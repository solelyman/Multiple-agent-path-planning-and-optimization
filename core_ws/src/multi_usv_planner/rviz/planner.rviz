      Enabled: false
      Line Style: Lines
      Line Width: 0.08
      Name: USV_4_Smooth
      Topic:
        Value: /usv_4/smooth_trajectory
      Value: true

    - Class: rviz_default_plugins/MarkerArray
      Enabled: true
