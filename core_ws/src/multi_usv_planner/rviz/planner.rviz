      Enabled: false
      Line Style: Lines
      Line Width: 0.08
      Name: USV_3_Smooth
      Topic:
        Value: /usv_3/smooth_trajectory
      Value: true
    - Class: rviz_default_plugins/RobotModel
      Description Source: Topic
      Description Topic:
        Value: /usv_4/robot_description
      Enabled: false
      Name: USV_4_Model
      Visual Enabled: true
    - Class: rviz_default_plugins/Path
